			onMouseOut="document.logo.src=logo1.src;">

			<img src="../Images/logo1.png" width="100" height="90" 
			 name="logo" style="border:none;" alt="company logo">

			</a>
		</div>
    	<img class="banner" src="../Images/banner.png" width="494" height="182" alt="banner image">
		<nav>
            <a href="../Home.html">Home</a>
            <a href="../AboutUs.html">About Us</a>
            <a href="../Tributes.html">Tributes</a>
